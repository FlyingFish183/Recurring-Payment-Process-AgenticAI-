# Aurora + IAM (hackathon)
AWS_REGION=us-east-1
DB_HOST=database-1.cluster-c0bagy6sg0oq.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_NAME=postgres
DATABASE_URL=postgresql://postgres@localhost:5432/postgres

# S3 — PDF → pdf/  ·  XML → XML/
S3_BUCKET=kfc-document-pdf

# SQS FIFO — extract / rule-validate worker
SQS_EXTRACT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/293221314416/extract-worker.fifo

PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=8h
# Digital signatures — HMAC by default; set KMS key for production CA/Cashier sign
SIGNING_SECRET=dev-signing-secret-change-me
# SIGNING_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# OpenAI — CA / Cashier SQL assistant chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
