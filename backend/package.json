{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/bin/www.ts",
    "start": "node dist/bin/www.js",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:test-iam": "tsx scripts/test-iam-connection.ts",
    "worker:extract": "tsx scripts/extract-worker.ts",
    "prisma:migrate:iam": "./scripts/prisma-iam.sh migrate dev",
    "prisma:seed:iam": "./scripts/prisma-iam.sh db seed",
    "db:reset": "prisma migrate reset --force"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/client-sqs": "^3.1085.0",
    "@aws-sdk/client-textract": "^3.1085.0",
    "@aws-sdk/rds-signer": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.10.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.15.32",
    "@types/pg": "^8.20.0",
    "jest": "^29.7.0",
    "prisma": "^6.10.1",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
